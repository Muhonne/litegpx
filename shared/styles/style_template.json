{
  "version": 8,
  "name": "TrailLite Local OSM",
  "glyphs": "asset://glyphs/{fontstack}/{range}.pbf",
  "sources": {
    "osm": {
      "type": "vector",
      "url": "TRAILLITE_TILE_URL"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#EEF2F3"
      }
    },
    {
      "id": "landcover-park",
      "type": "fill",
      "source": "osm",
      "source-layer": "landcover",
      "filter": ["==", "class", "park"],
      "paint": {
        "fill-color": "#CFE6C8",
        "fill-opacity": 0.75
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "osm",
      "source-layer": "water",
      "paint": {
        "fill-color": "#95C8E8"
      }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "osm",
      "source-layer": "buildings",
      "minzoom": 13,
      "layout": {
        "visibility": "none"
      },
      "paint": {
        "fill-color": "#C8C1B6",
        "fill-opacity": 0.58
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "osm",
      "source-layer": "water",
      "paint": {
        "line-color": "#76B7D8",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.4, 14, 1.6]
      }
    },
    {
      "id": "roads-minor",
      "type": "line",
      "source": "osm",
      "source-layer": "roads",
      "filter": ["in", ["get", "kind"], ["literal", ["minor_road", "other"]]],
      "paint": {
        "line-color": "#FFFFFF",
        "line-width": ["interpolate", ["linear"], ["zoom"], 9, 0.4, 15, 2.4]
      }
    },
    {
      "id": "paths-highlight",
      "type": "line",
      "source": "osm",
      "source-layer": "roads",
      "filter": ["in", ["get", "kind_detail"], ["literal", ["path", "track", "cycleway", "footway", "bridleway"]]],
      "paint": {
        "line-color": "#7B8F54",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.5, 15, 2.8],
        "line-dasharray": [1.4, 1.2]
      }
    },
    {
      "id": "roads-major",
      "type": "line",
      "source": "osm",
      "source-layer": "roads",
      "filter": ["in", ["get", "kind"], ["literal", ["highway", "major_road", "medium_road"]]],
      "paint": {
        "line-color": "#E7D4A5",
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 0.8, 15, 4.2]
      }
    },
    {
      "id": "street-names",
      "type": "symbol",
      "source": "osm",
      "source-layer": "roads",
      "minzoom": 12,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:fi"], ["get", "name"]],
        "text-font": ["Open Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 10, 16, 13],
        "text-letter-spacing": 0,
        "text-rotation-alignment": "map",
        "text-pitch-alignment": "viewport"
      },
      "paint": {
        "text-color": "#42505A",
        "text-halo-color": "#FFFFFF",
        "text-halo-width": 1.1
      }
    },
    {
      "id": "poi-dots",
      "type": "circle",
      "source": "osm",
      "source-layer": "pois",
      "minzoom": 14,
      "paint": {
        "circle-color": "#265C68",
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 14, 2.2, 17, 3.4],
        "circle-opacity": 0.82,
        "circle-stroke-color": "#FFFFFF",
        "circle-stroke-width": 1
      }
    },
    {
      "id": "poi-names",
      "type": "symbol",
      "source": "osm",
      "source-layer": "pois",
      "minzoom": 15,
      "layout": {
        "text-field": ["coalesce", ["get", "name:fi"], ["get", "name"]],
        "text-font": ["Open Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 15, 10, 18, 12],
        "text-letter-spacing": 0,
        "text-anchor": "top",
        "text-offset": [0, 0.55],
        "text-optional": true
      },
      "paint": {
        "text-color": "#17324D",
        "text-halo-color": "#FFFFFF",
        "text-halo-width": 1.2
      }
    }
  ]
}
