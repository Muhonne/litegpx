{
  "version": 8,
  "name": "TrailLite Local OSM",
  "glyphs": "asset://glyphs/{fontstack}/{range}.pbf",
  "sources": {
    "osm": {
      "type": "vector",
      "url": "TRAILLITE_TILE_URL"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#EEF2F3"
      }
    },
    {
      "id": "earth",
      "type": "fill",
      "source": "osm",
      "source-layer": "earth",
      "paint": {
        "fill-color": "#F8FAF7"
      }
    },
    {
      "id": "landuse-green",
      "type": "fill",
      "source": "osm",
      "source-layer": "landuse",
      "filter": ["in", ["get", "kind"], ["literal", ["forest", "grass", "park", "wood", "wetland", "nature_reserve"]]],
      "paint": {
        "fill-color": "#7A996C",
        "fill-opacity": 0.45
      }
    },
    {
      "id": "landcover-park",
      "type": "fill",
      "source": "osm",
      "source-layer": "landcover",
      "filter": ["in", ["get", "kind"], ["literal", ["forest", "grass", "park", "wood", "wetland"]]],
      "paint": {
        "fill-color": "#3F7137",
        "fill-opacity": 0.75
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "osm",
      "source-layer": "water",
      "filter": ["==", ["geometry-type"], "Polygon"],
      "paint": {
        "fill-color": "#2E7EA8"
      }
    },
    {
      "id": "boundaries",
      "type": "line",
      "source": "osm",
      "source-layer": "boundaries",
      "filter": [">=", ["get", "kind_detail"], 2],
      "paint": {
        "line-color": "#8B9699",
        "line-opacity": 0.65,
        "line-width": ["interpolate", ["linear"], ["zoom"], 4, 0.5, 10, 1.2]
      }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "osm",
      "source-layer": "buildings",
      "minzoom": 13,
      "paint": {
        "fill-color": "#8E8981",
        "fill-opacity": 1
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "osm",
      "source-layer": "water",
      "filter": ["==", ["geometry-type"], "LineString"],
      "paint": {
        "line-color": "#1E6D95",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.7, 14, 2.0]
      }
    },
    {
      "id": "roads-minor-casing",
      "type": "line",
      "source": "osm",
      "source-layer": "roads",
      "filter": ["in", ["get", "kind"], ["literal", ["minor_road", "other"]]],
      "paint": {
        "line-color": "#7A8583",
        "line-width": ["interpolate", ["linear"], ["zoom"], 9, 1.0, 15, 4.0]
      }
    },
    {
      "id": "roads-minor",
      "type": "line",
      "source": "osm",
      "source-layer": "roads",
      "filter": ["in", ["get", "kind"], ["literal", ["minor_road", "other"]]],
      "paint": {
        "line-color": "#596566",
        "line-width": ["interpolate", ["linear"], ["zoom"], 9, 0.5, 15, 2.8]
      }
    },
    {
      "id": "paths-highlight-casing",
      "type": "line",
      "source": "osm",
      "source-layer": "roads",
      "filter": [
        "any",
        ["==", ["get", "kind"], "path"],
        ["in", ["get", "kind_detail"], ["literal", ["path", "track", "cycleway", "footway", "bridleway"]]]
      ],
      "paint": {
        "line-color": "#EAF0E8",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 1.2, 15, 4.0]
      }
    },
    {
      "id": "paths-highlight",
      "type": "line",
      "source": "osm",
      "source-layer": "roads",
      "filter": [
        "any",
        ["==", ["get", "kind"], "path"],
        ["in", ["get", "kind_detail"], ["literal", ["path", "track", "cycleway", "footway", "bridleway"]]]
      ],
      "paint": {
        "line-color": "#4F6F2E",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.5, 15, 2.8],
        "line-dasharray": [1.4, 1.2]
      }
    },
    {
      "id": "roads-major-casing",
      "type": "line",
      "source": "osm",
      "source-layer": "roads",
      "filter": ["in", ["get", "kind"], ["literal", ["highway", "major_road", "medium_road"]]],
      "paint": {
        "line-color": "#697679",
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 1.4, 15, 6.0]
      }
    },
    {
      "id": "roads-major",
      "type": "line",
      "source": "osm",
      "source-layer": "roads",
      "filter": ["in", ["get", "kind"], ["literal", ["highway", "major_road", "medium_road"]]],
      "paint": {
        "line-color": "#4E5B5F",
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 0.8, 15, 4.6]
      }
    },
    {
      "id": "street-names",
      "type": "symbol",
      "source": "osm",
      "source-layer": "roads",
      "minzoom": 12,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:fi"], ["get", "name"]],
        "text-font": ["Open Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 10, 16, 13],
        "text-letter-spacing": 0,
        "text-rotation-alignment": "map",
        "text-pitch-alignment": "viewport"
      },
      "paint": {
        "text-color": "#42505A",
        "text-halo-color": "#FFFFFF",
        "text-halo-width": 1.1
      }
    },
    {
      "id": "poi-dots",
      "type": "circle",
      "source": "osm",
      "source-layer": "pois",
      "minzoom": 14,
      "paint": {
        "circle-color": "#265C68",
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 14, 2.2, 17, 3.4],
        "circle-opacity": 0.82,
        "circle-stroke-color": "#FFFFFF",
        "circle-stroke-width": 1
      }
    },
    {
      "id": "poi-names",
      "type": "symbol",
      "source": "osm",
      "source-layer": "pois",
      "minzoom": 15,
      "layout": {
        "text-field": ["coalesce", ["get", "name:fi"], ["get", "name"]],
        "text-font": ["Open Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 15, 10, 18, 12],
        "text-letter-spacing": 0,
        "text-anchor": "top",
        "text-offset": [0, 0.55],
        "text-optional": true
      },
      "paint": {
        "text-color": "#17324D",
        "text-halo-color": "#FFFFFF",
        "text-halo-width": 1.2
      }
    },
    {
      "id": "place-names",
      "type": "symbol",
      "source": "osm",
      "source-layer": "places",
      "minzoom": 5,
      "layout": {
        "text-field": ["coalesce", ["get", "name:fi"], ["get", "name"]],
        "text-font": ["Open Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 5, 10, 10, 14],
        "text-letter-spacing": 0,
        "text-anchor": "center",
        "text-optional": true
      },
      "paint": {
        "text-color": "#334350",
        "text-halo-color": "#F8FAF7",
        "text-halo-width": 1.2
      }
    }
  ]
}
